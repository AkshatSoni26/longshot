# Redis connection (override in docker-compose; localhost when running natively)
REDIS_URL=redis://localhost:6379/0

# --- LLM mode ----------------------------------------------------------------
# One of: mock | real | lmstudio
#   mock      - deterministic stub (no network). Default; runs anywhere.
#   real      - Anthropic Messages API. Needs ANTHROPIC_API_KEY + `uv sync --extra real`.
#   lmstudio  - local LM Studio server, OpenAI-compatible. Free for local dev/testing.
LLM_MODE=mock

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- LM Studio ---------------------------------------------------------------
# 1. Open LM Studio.
# 2. Click "+ Load Model" and pick a chat model (Qwen3, Llama-3.1, Mistral, ...).
# 3. The "Local Server" tab should show "Status: Running" and a base URL.
# 4. Set LMSTUDIO_BASE_URL below to that URL with /v1 appended.
#
# In Docker, host.docker.internal is the host machine — that's the default.
# Running natively?  Use http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
# Empty = use whatever model LM Studio has loaded. Set this to override
# (e.g. when juggling several models).
# Example for the Qwen3-30B-A3B-Thinking GGUF:
#   LMSTUDIO_MODEL=qwen_qwen3-30b-a3b-thinking-2507
LMSTUDIO_MODEL=
LMSTUDIO_TIMEOUT_SECONDS=120
# Token cap per call. Thinking models (Qwen3-Thinking, DeepSeek-R1) burn
# many tokens in <think>...</think> before answering — keep this generous.
LMSTUDIO_MAX_TOKENS=2048
LMSTUDIO_TEMPERATURE=0.3
# Strip <think>...</think> blocks from responses. True = clean summaries
# whether the model is a thinking variant or not.
LMSTUDIO_STRIP_THINKING=true

# --- Worker / timeouts -------------------------------------------------------
WORKER_CONSUMER_NAME=worker-1
TASK_HARD_TIMEOUT_SECONDS=120
