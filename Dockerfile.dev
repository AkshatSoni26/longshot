# Development image — same as Dockerfile but optimized for live reloading.
#
# Differences from the prod Dockerfile:
#   * Source is *not* baked in — docker-compose.dev.yml mounts ./app and ./static
#   * Includes the dev extras (pytest, ruff) so you can `make test` inside the container
#   * The default command is overridden by compose to add --reload flags
#
# Build & run via: `make dev-up` (which calls docker-compose.dev.yml)

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=0

# Install uv via pip — avoids depending on ghcr.io being reachable.
RUN pip install --no-cache-dir uv

WORKDIR /app

# Install deps first (including dev extras) so this layer is cached across edits.
COPY pyproject.toml README.md ./
RUN uv venv && uv sync --extra dev

# We DON'T copy the source. docker-compose.dev.yml bind-mounts ./app and ./static.

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8000

# Compose overrides this for the worker service.
CMD ["uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/app", "--reload-dir", "/app/static"]
